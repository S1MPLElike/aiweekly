APP_PORT=8080

# MySQL example:
# MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/aiweekly?charset=utf8mb4&parseTime=True&loc=Local
MYSQL_DSN=root:187415157@tcp(127.0.0.1:3306)/aiweekly?charset=utf8mb4&parseTime=True&loc=Local

# JWT secret for signing tokens
JWT_SECRET=

# Optional overrides
ACCESS_TOKEN_TTL=2h
REFRESH_TOKEN_TTL=168h

# CORS: comma-separated origins, used with AllowCredentials=true
CORS_ALLOW_ORIGINS=http://localhost:5173

# Cookie options (for https production)
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Deepseek API Key for LLM


